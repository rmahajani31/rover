<?xml version="1.0"?>
<robot name="rover">

  <!-- Root -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4826 0.4826 0.3556"/>
      </geometry>
    </visual>
  </link>

  <!-- LiDAR frame must be named exactly "laser" to match your TF -->
  <link name="laser"/>
  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <!-- Put the real measured pose here -->
    <origin xyz="0 0 0.2032" rpy="0 0 0"/>
  </joint>

  <!-- Camera frame must be named exactly "camera_link" -->
  <link name="camera_link"/>
  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0.2159 0.1651" rpy="0 0 0"/>
  </joint>

</robot>